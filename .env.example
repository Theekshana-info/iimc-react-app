# --- Supabase ---
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_anon_key"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"

# --- PayHere ---
VITE_PAYHERE_MERCHANT_ID="your_merchant_id"
VITE_PAYHERE_SANDBOX="true" # Set to "false" in production

# NOTE: The following secrets must be set via `supabase secrets set` in your project:
# - PAYHERE_MERCHANT_ID
# - PAYHERE_MERCHANT_SECRET
# - ALLOWED_ORIGIN (e.g. "https://yourdomain.com")

# --- Cloudflare Turnstile ---
VITE_TURNSTILE_SITE_KEY="your_turnstile_site_key"
# NOTE: TURNSTILE_SECRET_KEY must be set in Vercel Environment Variables (not here).
# It is a server-only secret used by the /api/turnstile/verify serverless function.

