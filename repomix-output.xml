                {bankDetails && bankDetails.length > 0 ? (
                  bankDetails.map((bank) => (
                    <div key={bank.id} className="p-4 bg-muted/50 rounded-lg border border-border space-y-2">
                      <div className="grid grid-cols-2 gap-2 text-sm">
