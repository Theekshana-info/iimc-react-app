                    >
                      Learn More
                    </Button>
                  </CardContent>
                </Card>
              </ScrollReveal>
            ))}
          </div>

          <ScrollReveal delay={300}>
            <div className="text-center mt-12">
              <Button
                variant="outline"
                size="lg"
                onClick={() => navigate('/events')}
                className="hover-lift"
              >
                View All Events
              </Button>
            </div>
          </ScrollReveal>
        </section>
      )}
    </div>
  );
}
